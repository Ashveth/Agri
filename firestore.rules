rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Farmer Profile Rules
    match /farmers/{farmerId} {
      function isValidFarmer(data) {
        return data.size() >= 4 && data.size() <= 10
          && data.uid == request.auth.uid
          && data.phoneNumber is string && data.phoneNumber.size() <= 20
          && data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.location is string && data.location.size() > 0 && data.location.size() <= 200
          && (!('age' in data) || (data.age is number && data.age >= 0 && data.age <= 150))
          && (!('farms' in data) || (data.farms is string && data.farms.size() <= 1000))
          && (!('profilePhoto' in data) || (data.profilePhoto is string && data.profilePhoto.size() <= 1000));
      }

      allow get: if isOwner(farmerId);
      allow list: if false; // Farmers shouldn't list each other by default
      
      allow create: if isOwner(farmerId) 
        && isValidFarmer(request.resource.data)
        && request.resource.data.createdAt == request.time;
        
      allow update: if isOwner(farmerId)
        && isValidFarmer(request.resource.data)
        && request.resource.data.uid == resource.data.uid // Immutable
        && request.resource.data.phoneNumber == resource.data.phoneNumber // Immutable
        && request.resource.data.updatedAt == request.time;

      allow delete: if false; // Farmers can't delete their own accounts via client
    }

    // Prediction Rules
    match /predictions/{predictionId} {
      function isValidPrediction(data) {
        return data.userId == request.auth.uid
          && data.product is string && data.product.size() <= 100
          && data.location is string && data.location.size() <= 200
          && data.demand in ['High', 'Medium', 'Low', 'Stable']
          && data.price is number
          && data.bestLocation is string && data.bestLocation.size() <= 200
          && data.bestTime is string && data.bestTime.size() <= 200
          && data.trend is string && data.trend.size() <= 200
          && data.date is string && data.date.size() <= 100
          && data.id == predictionId;
      }

      allow get, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidPrediction(request.resource.data)
        && request.resource.data.createdAt == request.time;
        
      allow update, delete: if false; // Predictions are immutable records for farmers
    }
  }
}
